# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
apps/*/node_modules
apps/*/dist
apps/*/release
apps/*/out
apps/*/.env
apps/*/.env.*
!apps/*/.env.example
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.b64

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# On-Device AI Camera Integrity Detection v1 — Evidence Frames, local dev
# storage only (see src/lib/evidenceStorage.ts). Never used in production —
# a real object storage provider must be configured there.
/.evidence-storage
