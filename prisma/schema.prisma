generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  LECTURER
  STUDENT
}

enum QuestionType {
  MULTIPLE_CHOICE
  SHORT_ANSWER
  ESSAY
}

enum SubmissionStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum IntegrityEventType {
  FULLSCREEN_EXIT
  WINDOW_BLUR
  WINDOW_FOCUS_RETURN
  COPY_ATTEMPT
  PASTE_ATTEMPT
  RIGHT_CLICK_ATTEMPT
  DEVTOOLS_SUSPECTED
  NETWORK_OFFLINE
  NETWORK_ONLINE
  AUTOSAVE_FAILED
  TIMER_EXPIRED
  SUBMIT_AFTER_DEADLINE
  MANUAL_WARNING
}

enum IntegritySeverity {
  INFO
  LOW
  MEDIUM
  HIGH
}

enum CanvasPassbackStatus {
  NOT_READY
  PENDING
  SENT
  FAILED
  SKIPPED
}

model User {
  id                String           @id @default(cuid())
  name              String
  email             String           @unique
  passwordHash      String
  role              Role
  createdAt         DateTime         @default(now())
  examsCreated      Exam[]           @relation("ExamCreator")
  submissions       Submission[]
  integrityEvents   IntegrityEvent[] @relation("IntegrityEventStudent")
  resolvedEvents     IntegrityEvent[] @relation("IntegrityEventResolver")
  canvasUserId      String?          @unique
  canvasCourseIds   String[]         @default([])
}

model Exam {
  id              String           @id @default(cuid())
  title           String
  description     String?
  durationMins    Int
  published       Boolean          @default(false)
  startsAt        DateTime?
  endsAt          DateTime?
  createdById     String
  createdBy       User             @relation("ExamCreator", fields: [createdById], references: [id])
  questions       Question[]
  submissions     Submission[]
  integrityEvents IntegrityEvent[]
  createdAt       DateTime         @default(now())
}

model Question {
  id            String       @id @default(cuid())
  examId        String
  exam          Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  type          QuestionType
  text          String
  options       Json?
  correctAnswer String?
  points        Int          @default(1)
  order         Int          @default(0)
  answers       Answer[]
}

model Submission {
  id          String           @id @default(cuid())
  examId      String
  exam        Exam             @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId   String
  student     User             @relation(fields: [studentId], references: [id])
  status      SubmissionStatus @default(IN_PROGRESS)
  startedAt   DateTime         @default(now())
  submittedAt DateTime?
  gradedAt    DateTime?
  totalScore  Int?
  answers     Answer[]
  integrityEvents IntegrityEvent[]
  gradePassback   CanvasGradePassback?

  @@unique([examId, studentId])
}

model Answer {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  response          String?
  score             Int?
  feedback          String?
  isCorrect         Boolean?
  timeSpentSeconds  Int?
  aiDraftScore      Float?
  aiReasoning       String?
  aiGradedAt        DateTime?

  @@unique([submissionId, questionId])
}

model IntegrityEvent {
  id             String             @id @default(cuid())
  submissionId   String
  submission     Submission         @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  examId         String
  exam           Exam               @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId      String
  student        User               @relation("IntegrityEventStudent", fields: [studentId], references: [id])
  eventType      IntegrityEventType
  severity       IntegritySeverity
  message        String
  metadataJson   Json?
  occurredAt     DateTime
  createdAt      DateTime           @default(now())
  resolvedAt     DateTime?
  resolvedById   String?
  resolvedBy     User?              @relation("IntegrityEventResolver", fields: [resolvedById], references: [id])
  resolutionNote String?

  @@index([submissionId])
  @@index([examId])
  @@index([studentId])
  @@index([eventType])
  @@index([severity])
  @@index([occurredAt])
}

model LtiPlatform {
  id            String       @id @default(cuid())
  issuer        String       @unique
  clientId      String
  authEndpoint  String
  tokenEndpoint String
  jwksUrl       String
  deploymentId  String
  createdAt     DateTime     @default(now())
  sessions      LtiSession[]
}

model LtiSession {
  id         String      @id @default(cuid())
  platform   LtiPlatform @relation(fields: [platformId], references: [id])
  platformId String
  nonce      String      @unique
  state      String      @unique
  expiresAt  DateTime
  consumed   Boolean     @default(false)
  createdAt  DateTime    @default(now())
}

model LtiLaunch {
  id                 String   @id @default(cuid())
  platformId         String
  canvasUserId       String
  canvasCourseId     String
  canvasAssignmentId String?
  lineitems          String?
  sourcedid          String?
  examId             String?
  submissionId       String?
  // --- AGS hardening (additive) ---
  deploymentId       String?
  resourceLinkId     String?
  lineitemUrl        String?
  lineitemsUrl       String?
  agsScopeJson       Json?
  // Raw verified launch claims, kept server-side only for debugging.
  // Never returned to students or in any client-facing API response.
  launchClaimsJson   Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  gradePassbacks     CanvasGradePassback[]
}

model CanvasGradePassback {
  id                 String               @id @default(cuid())
  submissionId       String               @unique
  submission         Submission           @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  ltiLaunchId        String?
  ltiLaunch          LtiLaunch?           @relation(fields: [ltiLaunchId], references: [id])
  status             CanvasPassbackStatus @default(NOT_READY)
  scoreGiven         Float?
  scoreMaximum       Float?
  scorePct           Float?
  attemptedAt        DateTime?
  sentAt             DateTime?
  errorMessage       String?
  canvasResponseJson Json?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([status])
}
