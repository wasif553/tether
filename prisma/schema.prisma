generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  LECTURER
  STUDENT
  PLATFORM_ADMIN
}

enum QuestionType {
  MULTIPLE_CHOICE
  SHORT_ANSWER
  ESSAY
}

enum SubmissionStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum IntegrityEventType {
  FULLSCREEN_EXIT
  WINDOW_BLUR
  WINDOW_FOCUS_RETURN
  COPY_ATTEMPT
  PASTE_ATTEMPT
  RIGHT_CLICK_ATTEMPT
  DEVTOOLS_SUSPECTED
  NETWORK_OFFLINE
  NETWORK_ONLINE
  AUTOSAVE_FAILED
  TIMER_EXPIRED
  SUBMIT_AFTER_DEADLINE
  MANUAL_WARNING
  // Camera Monitoring v1 (additive — see docs/secure-exam-threat-model.md)
  CAMERA_PERMISSION_GRANTED
  CAMERA_PERMISSION_DENIED
  CAMERA_STARTED
  CAMERA_STOPPED
  CAMERA_UNAVAILABLE
  CAMERA_HEARTBEAT_MISSED
  CAMERA_PRECHECK_FAILED
  // Browser-Level Friction v1 (additive)
  KEYBOARD_SHORTCUT_BLOCKED
  FULLSCREEN_FORCED_RETURN
  // Optional Student Verification + On-Device AI Camera Integrity
  // Detection v1 (additive — see
  // docs/on-device-ai-integrity-detection-v1.md). All AI signals are
  // metadata-only: no image, frame, or video data is ever stored.
  STUDENT_VERIFICATION_CONFIRMED
  POSSIBLE_PHONE_VISIBLE
  POSSIBLE_SECOND_PERSON_VISIBLE
  NO_PERSON_VISIBLE
  CAMERA_VIEW_BLOCKED
  CAMERA_TOO_DARK
  AI_CAMERA_CHECK_UNAVAILABLE
  // One-Question-At-A-Time Exam Delivery v1 (additive — see
  // docs/one-question-delivery-v1.md).
  QUESTION_NAVIGATED_NEXT
  QUESTION_NAVIGATED_PREVIOUS
  QUESTION_BACK_NAVIGATION_BLOCKED
  // Question Navigator v1 (additive — see docs/question-navigator-v1.md).
  // Only used when allowQuestionJumping is true and a request actually
  // jumps more than one position; adjacent Next/Previous moves keep
  // using the existing QUESTION_NAVIGATED_NEXT/PREVIOUS types above.
  QUESTION_NAVIGATED_DIRECT
  QUESTION_DIRECT_NAVIGATION_BLOCKED
  // Controlled AI Brainstorming Assistance v1 (additive — see
  // docs/controlled-ai-brainstorming-assistance-v1.md). Neutral,
  // operational events only — this is an ALLOWED assessment resource,
  // never treated as misconduct, so none of these carry any integrity
  // risk weight (see severityFor in src/lib/secureExam.ts).
  AI_ASSISTANCE_USED
  AI_ASSISTANCE_REQUEST_BLOCKED
  AI_ASSISTANCE_LIMIT_REACHED
  AI_ASSISTANCE_RESPONSE_REGENERATED
}

enum IntegritySeverity {
  INFO
  LOW
  MEDIUM
  HIGH
}

enum CanvasPassbackStatus {
  NOT_READY
  PENDING
  SENT
  FAILED
  SKIPPED
}

// Course, Enrolment, Exam Assignment, Scheduling v1 — see
// docs/course-enrolment-and-exam-assignment.md.
enum CourseRole {
  STUDENT
  LECTURER
}

enum ExamAssignmentMode {
  COURSE
  SELECTED_STUDENTS
}

// Multi-Tenant Architecture v1 — see docs/multi-tenant-migration.md.
model Institution {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  domain       String?
  plan         String        @default("pilot")
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  users        User[]
  exams        Exam[]
  ltiPlatforms LtiPlatform[]
  courses      Course[]
}

// Platform Admin Onboarding v2 — minimal audit trail for platform-admin
// actions (institution create/update, lecturer invite). See
// docs/platform-admin-onboarding.md. actorId/institutionId are SetNull
// on delete so a log entry survives the actor or institution being
// removed, rather than cascading away the audit trail.
model PlatformAuditLog {
  id            String   @id @default(cuid())
  actorId       String?
  actor         User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action        String
  targetType    String
  targetId      String?
  institutionId String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([actorId])
  @@index([institutionId])
  @@index([action])
  @@index([createdAt])
}

model User {
  id                String           @id @default(cuid())
  name              String
  email             String           @unique
  passwordHash      String
  role              Role
  createdAt         DateTime         @default(now())
  examsCreated      Exam[]           @relation("ExamCreator")
  submissions       Submission[]
  integrityEvents   IntegrityEvent[] @relation("IntegrityEventStudent")
  resolvedEvents    IntegrityEvent[] @relation("IntegrityEventResolver")
  networkEvidence   NetworkEvidence[] @relation("NetworkEvidenceStudent")
  // canvasUserId is unique per institution, not globally — a self-hosted
  // Canvas instance at a different institution could otherwise collide
  // with another institution's user id. See docs/multi-tenant-migration.md.
  canvasUserId      String?
  canvasCourseIds   String[]         @default([])
  questionBanks     QuestionBank[]
  // Multi-Tenant Architecture v1 (additive, nullable — see
  // docs/multi-tenant-migration.md). Nullable at the DB level; application
  // code treats it as required via src/lib/institutionScope.ts.
  institutionId     String?
  institution       Institution?     @relation(fields: [institutionId], references: [id])
  // Platform Admin Onboarding v2 — see docs/platform-admin-onboarding.md.
  platformAuditLogs PlatformAuditLog[]
  // Course, Enrolment, Exam Assignment, Scheduling v1 — see
  // docs/course-enrolment-and-exam-assignment.md.
  courseEnrollments CourseEnrollment[]
  examAssignments   ExamAssignment[]
  // Assessment Operations v1 (additive) — see
  // docs/assessment-operations-v1.md. An optional institution-issued
  // student ID (e.g. a roll number or SIS ID), distinct from this row's
  // database id and never used as a login credential. Not unique-
  // constrained at the DB level in v1 — see that doc for why uniqueness
  // is deferred to a future release rather than enforced here.
  institutionStudentId String?

  // Answer Similarity Review + Oral Verification v1 (additive) — see
  // docs/answer-similarity-review-v1.md and
  // docs/oral-verification-workflow-v1.md.
  reviewedSimilarityMatches  SubmissionSimilarityMatch[] @relation("SimilarityMatchReviewer")
  oralVerificationsRequested OralVerification[]          @relation("OralVerificationRequestedBy")
  oralVerificationsCompleted OralVerification[]          @relation("OralVerificationCompletedBy")

  // AI-Use Answer Review v1 (additive) — see docs/ai-use-answer-review-v1.md.
  aiUseReviewAnalysesRequested AiUseReviewAnalysis[] @relation("AiUseReviewRequestedBy")
  reviewedAiUseReviewSignals   AiUseReviewSignal[]    @relation("AiUseReviewSignalReviewer")

  // Exam Session Binding + Time Anomaly Review v1 (additive) — see
  // docs/exam-session-binding-v1.md and docs/time-anomaly-review-v1.md.
  examAttemptSessions              ExamAttemptSession[]      @relation("ExamAttemptSessionUser")
  reviewedSessionIntegritySignals  SessionIntegritySignal[]  @relation("SessionIntegritySignalReviewer")
  timingAnalysesRequested          TimingAnalysis[]          @relation("TimingAnalysisRequestedBy")
  reviewedTimingIntegritySignals   TimingIntegritySignal[]   @relation("TimingIntegritySignalReviewer")

  // Exam Design Policy + Evidence Review v1 (additive) — see
  // docs/evidence-review-workflow-v1.md.
  reviewedIntegrityEvents      IntegrityEvent[]                @relation("IntegrityEventReviewer")
  integrityReviewComments      IntegrityReviewComment[]        @relation("IntegrityReviewCommentAuthor")
  integrityReviewStatusChanges IntegrityReviewStatusHistory[]  @relation("IntegrityReviewStatusChanger")

  // Controlled AI Brainstorming Assistance v1 (additive) — see
  // docs/controlled-ai-brainstorming-assistance-v1.md.
  aiAssistanceInteractions AiAssistanceInteraction[]

  @@unique([institutionId, canvasUserId])
  @@index([institutionId])
}

model Exam {
  id              String           @id @default(cuid())
  title           String
  description     String?
  durationMins    Int
  published       Boolean          @default(false)
  startsAt        DateTime?
  endsAt          DateTime?
  createdById     String
  createdBy       User             @relation("ExamCreator", fields: [createdById], references: [id])
  questions       Question[]
  submissions     Submission[]
  integrityEvents  IntegrityEvent[]
  ltiExamLinks     LtiExamLink[]
  networkEvidence  NetworkEvidence[]
  // On-Device AI Camera Integrity Detection v1 — Evidence Frames
  // (additive, opt-in). See docs/on-device-ai-integrity-detection-v1.md.
  evidenceAssets   IntegrityEvidenceAsset[]
  // Secure Exam Mode v1 settings (see src/lib/secureExam.ts for shape/defaults).
  // A single JSON column rather than ~10 booleans/ints, since this app has no
  // other multi-flag settings model and these are read/written together.
  secureSettings  Json?
  createdAt       DateTime         @default(now())
  // Multi-Tenant Architecture v1 (additive, nullable) — see
  // docs/multi-tenant-migration.md.
  institutionId   String?
  institution     Institution?     @relation(fields: [institutionId], references: [id])
  // Student Onboarding and Exam Access v1 (additive) — see
  // docs/student-onboarding-and-exam-access.md. Never store the plaintext
  // code; accessCodeRequired is a separate flag (not just "hash is set")
  // so clearing the code is an explicit, unambiguous action.
  accessCodeHash     String?
  accessCodeRequired Boolean       @default(false)
  // Assessment Lifecycle v1: exam-level marks release. Students only see
  // score/feedback data after this is set by the owning lecturer/admin.
  marksReleasedAt    DateTime?
  marksReleasedById  String?

  // Course, Enrolment, Exam Assignment, Scheduling v1 — see
  // docs/course-enrolment-and-exam-assignment.md. courseId is nullable:
  // a null value means this is a legacy institution-wide exam, which
  // remains visible to every student in the institution exactly as
  // before this feature — see that doc for the full legacy-visibility
  // rule and its test coverage.
  courseId       String?
  course         Course?            @relation(fields: [courseId], references: [id])
  assignmentMode ExamAssignmentMode @default(COURSE)
  assignments    ExamAssignment[]
  // Scheduled availability window — distinct from the pre-existing
  // startsAt/endsAt (which historically doubled as both "exam metadata"
  // and "availability window"). availableFrom/availableUntil are the new,
  // explicit scheduling fields; both remain optional so unset exams have
  // no window restriction (see docs/course-enrolment-and-exam-assignment.md).
  availableFrom    DateTime?
  availableUntil   DateTime?

  // Question Pools v1 (additive, opt-in) — see docs/question-pools-v1.md.
  questionPools QuestionPool[]

  // Answer Similarity Review v1 (additive) — see
  // docs/answer-similarity-review-v1.md.
  similarityAnalyses SubmissionSimilarityAnalysis[]

  // AI-Use Answer Review v1 (additive) — see docs/ai-use-answer-review-v1.md.
  aiUseReviewAnalyses AiUseReviewAnalysis[]

  // Exam Session Binding + Time Anomaly Review v1 (additive) — see
  // docs/time-anomaly-review-v1.md.
  timingAnalyses TimingAnalysis[]

  @@index([institutionId])
  @@index([courseId])
}

// Question Pools v1 (additive, opt-in) — see docs/question-pools-v1.md.
// A lecturer-defined group of interchangeable questions within one exam;
// each student attempt draws `drawCount` questions at random from each
// pool at attempt start (see buildSelectedQuestionIds() in
// src/lib/questionDelivery.ts). Questions never assigned to a pool
// (Question.questionPoolId null) are always included for every student —
// see docs/question-pools-v1.md, "Unpooled questions."
model QuestionPool {
  id          String     @id @default(cuid())
  examId      String
  exam        Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  name        String
  description String?
  // Number of questions to draw from this pool per attempt. Null (or <= 0)
  // means "include every question in this pool" — see
  // docs/question-pools-v1.md. If greater than the number of questions
  // actually in the pool, every available question is included instead
  // of erroring.
  drawCount Int?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  questions Question[]

  @@index([examId])
}

model Question {
  id            String       @id @default(cuid())
  examId        String
  exam          Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  type          QuestionType
  text          String
  options       Json?
  correctAnswer String?
  points        Int          @default(1)
  order         Int          @default(0)
  // Question Pools v1 (additive, opt-in, nullable) — see
  // docs/question-pools-v1.md. Null means "not in any pool" — always
  // included for every student regardless of pool settings.
  questionPoolId String?
  questionPool   QuestionPool? @relation(fields: [questionPoolId], references: [id], onDelete: SetNull)
  answers       Answer[]
  // Answer Similarity Review v1 (additive) — see
  // docs/answer-similarity-review-v1.md.
  similarityMatches SubmissionSimilarityMatch[]
  // AI-Use Answer Review v1 (additive) — see docs/ai-use-answer-review-v1.md.
  aiUseReviewSignals AiUseReviewSignal[]
  // Exam Session Binding + Time Anomaly Review v1 (additive) — see
  // docs/exam-session-binding-v1.md.
  answerActivityEvents AnswerActivityEvent[]
  // Question Navigator v1 (additive, opt-in) — see
  // docs/question-navigator-v1.md.
  submissionQuestionStates SubmissionQuestionState[]
  // Controlled AI Brainstorming Assistance v1 (additive, opt-in) — see
  // docs/controlled-ai-brainstorming-assistance-v1.md.
  aiAssistanceInteractions AiAssistanceInteraction[]
}

// Answer Similarity Review v1 (additive) — see
// docs/answer-similarity-review-v1.md. One row per analysis run of one
// exam's submitted cohort. Status/risk fields are validated strings, not
// Prisma enums, following the IntegrityEvidenceAsset convention (plain
// String columns keep the production migration purely additive with no
// enum-alteration risk); validation lives in src/lib/answerSimilarity.ts.
// Everything here is a REVIEW SIGNAL for a human lecturer — never an
// automatic misconduct finding, never a grade input.
model SubmissionSimilarityAnalysis {
  id     String @id @default(cuid())
  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)
  // Set when the run was scoped to a single submission; null for a
  // whole-exam run (the v1 default).
  submissionId     String?
  status           String    @default("PENDING") // PENDING | PROCESSING | COMPLETE | FAILED
  overallRisk      String    @default("NONE") // NONE | LOW | MEDIUM | HIGH
  analysedAt       DateTime?
  algorithmVersion String
  summaryJson      Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  matches          SubmissionSimilarityMatch[]

  @@index([examId])
  @@index([status])
}

// One flagged pair (source vs compared submission, optionally scoped to
// one question) with an explainable signal — see
// docs/answer-similarity-review-v1.md. Pair ordering is canonical
// (sourceSubmissionId < comparedSubmissionId lexicographically) so A-vs-B
// and B-vs-A never produce duplicate rows.
model SubmissionSimilarityMatch {
  id                   String                       @id @default(cuid())
  analysisId           String
  analysis             SubmissionSimilarityAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  sourceSubmissionId   String
  sourceSubmission     Submission                   @relation("SimilarityMatchSource", fields: [sourceSubmissionId], references: [id], onDelete: Cascade)
  comparedSubmissionId String
  comparedSubmission   Submission                   @relation("SimilarityMatchCompared", fields: [comparedSubmissionId], references: [id], onDelete: Cascade)
  questionId           String?
  question             Question?                    @relation(fields: [questionId], references: [id], onDelete: SetNull)
  signalType           String // IDENTICAL_SHORT_ANSWER | HIGH_TEXT_SIMILARITY | SAME_WRONG_MCQ_PATTERN
  score                Float
  matchedDetailJson    Json?
  reviewStatus         String                       @default("NEEDS_REVIEW") // NEEDS_REVIEW | REVIEWED_NO_CONCERN | REVIEWED_CONCERN_REMAINS | ESCALATED | RESOLVED
  reviewedAt           DateTime?
  reviewedById         String?
  reviewedBy           User?                        @relation("SimilarityMatchReviewer", fields: [reviewedById], references: [id])
  reviewNote           String?
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt

  @@index([analysisId])
  @@index([sourceSubmissionId])
  @@index([comparedSubmissionId])
  @@index([questionId])
  @@index([reviewStatus])
}

// Oral Verification Workflow v1 (additive) — see
// docs/oral-verification-workflow-v1.md. Only ever created by an
// explicit lecturer action ("Require oral verification") — never
// automatically. lecturerNotes are private to staff and never exposed to
// any student-facing route.
model OralVerification {
  id                     String     @id @default(cuid())
  submissionId           String
  submission             Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  requestedById          String
  requestedBy            User       @relation("OralVerificationRequestedBy", fields: [requestedById], references: [id])
  status                 String     @default("REQUIRED") // NOT_REQUIRED | REQUIRED | SCHEDULED | COMPLETED_NO_CONCERN | COMPLETED_CONCERN_REMAINS | CANCELLED
  reason                 String
  scheduledAt            DateTime?
  completedAt            DateTime?
  completedById          String?
  completedBy            User?      @relation("OralVerificationCompletedBy", fields: [completedById], references: [id])
  outcome                String?
  lecturerNotes          String?
  generatedQuestionsJson Json?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  @@index([submissionId])
  @@index([status])
}

model Submission {
  id          String           @id @default(cuid())
  examId      String
  exam        Exam             @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId   String
  student     User             @relation(fields: [studentId], references: [id])
  status      SubmissionStatus @default(IN_PROGRESS)
  attemptNumber Int              @default(1)
  startedAt   DateTime         @default(now())
  submittedAt DateTime?
  gradedAt    DateTime?
  totalScore  Int?
  answers     Answer[]
  integrityEvents IntegrityEvent[]
  gradePassback   CanvasGradePassback?
  networkEvidence NetworkEvidence[]
  // On-Device AI Camera Integrity Detection v1 — Evidence Frames
  // (additive, opt-in). See docs/on-device-ai-integrity-detection-v1.md.
  evidenceAssets  IntegrityEvidenceAsset[]

  // One-Question-At-A-Time Exam Delivery v1 (additive, opt-in) — see
  // docs/one-question-delivery-v1.md. questionOrderJson stores the
  // stable per-submission question order (and, if randomiseMcqOptionOrder
  // is on, per-question MCQ option order) generated once at attempt
  // start — never recomputed, so it survives refresh. Null when
  // randomiseQuestionOrder was off at attempt start (falls back to the
  // exam's original Question.order at read time). currentQuestionIndex
  // is the student's furthest/current position when
  // oneQuestionAtATime is enabled; unused (stays 0) otherwise.
  questionOrderJson    Json?
  currentQuestionIndex Int   @default(0)

  // Answer Similarity Review + Oral Verification v1 (additive) — see
  // docs/answer-similarity-review-v1.md and
  // docs/oral-verification-workflow-v1.md.
  similarityMatchesAsSource   SubmissionSimilarityMatch[] @relation("SimilarityMatchSource")
  similarityMatchesAsCompared SubmissionSimilarityMatch[] @relation("SimilarityMatchCompared")
  oralVerifications           OralVerification[]

  // AI-Use Answer Review v1 (additive) — see docs/ai-use-answer-review-v1.md.
  aiUseReviewAnalysis AiUseReviewAnalysis?

  // Exam Session Binding + Time Anomaly Review v1 (additive) — see
  // docs/exam-session-binding-v1.md and docs/time-anomaly-review-v1.md.
  examAttemptSessions      ExamAttemptSession[]
  sessionIntegritySignals  SessionIntegritySignal[]
  answerActivityEvents     AnswerActivityEvent[]
  timingAnalysis           TimingAnalysis?

  // Exam Design Policy + Evidence Review v1 (additive) — see
  // docs/exam-design-policy-v1.md. The immutable policy snapshot taken
  // at attempt start (see src/lib/examPolicy.ts:buildExamPolicySnapshot).
  // Null for every submission created before this feature shipped, and
  // for any exam where no policy was ever configured — a null snapshot
  // is never treated as evidence of anything, and this attempt's
  // integrity signals are always interpreted with UNKNOWN policy
  // alignment rather than retrospectively judged against a policy that
  // did not exist when the attempt happened. Never rewritten after
  // creation, even if the exam's own secureSettings/policy change later.
  examPolicySnapshotJson Json?
  integrityReviewComments       IntegrityReviewComment[]
  integrityReviewStatusHistory  IntegrityReviewStatusHistory[]

  // Question Navigator v1 (additive, opt-in) — see
  // docs/question-navigator-v1.md.
  questionStates SubmissionQuestionState[]

  // Controlled AI Brainstorming Assistance v1 (additive, opt-in) — see
  // docs/controlled-ai-brainstorming-assistance-v1.md. The effective AI-
  // assistance policy (mode + limits + allowed-capability flags) copied
  // at attempt start — exactly the same immutable-snapshot pattern as
  // examPolicySnapshotJson above. All later assistance decisions for this
  // attempt (limits, allowed capabilities) MUST read this snapshot, never
  // the exam's current (possibly since-changed) secureSettings. Null for
  // every submission created before this feature shipped, or where AI
  // assistance was never configured — always treated as DISABLED, never
  // silently active.
  aiAssistancePolicySnapshotJson Json?
  aiAssistanceInteractions       AiAssistanceInteraction[]

  @@unique([examId, studentId, attemptNumber])
  @@index([examId, studentId])
}

// Question Navigator v1 (additive, opt-in) — see
// docs/question-navigator-v1.md. Tracks ONLY visited/flagged state per
// question per submission — never a copy of the answer text (that stays
// solely in Answer.response; "answered" is always derived from there).
// One row per question the student has visited and/or flagged; a
// question with no row is simply "not visited, not flagged" — no row is
// ever required to exist.
model SubmissionQuestionState {
  id             String     @id @default(cuid())
  submissionId   String
  submission     Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId     String
  question       Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  firstVisitedAt DateTime?
  lastVisitedAt  DateTime?
  flaggedForReview Boolean  @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([submissionId, questionId])
  @@index([submissionId])
  @@index([questionId])
  @@index([submissionId, flaggedForReview])
}

model Answer {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  response          String?
  score             Int?
  feedback          String?
  isCorrect         Boolean?
  timeSpentSeconds  Int?
  aiDraftScore      Float?
  aiReasoning       String?
  aiGradedAt        DateTime?
  // AI-Use Answer Review v1 (additive) — see docs/ai-use-answer-review-v1.md.
  aiUseReviewSignals AiUseReviewSignal[]

  @@unique([submissionId, questionId])
}

model IntegrityEvent {
  id             String             @id @default(cuid())
  submissionId   String
  submission     Submission         @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  examId         String
  exam           Exam               @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId      String
  student        User               @relation("IntegrityEventStudent", fields: [studentId], references: [id])
  eventType      IntegrityEventType
  severity       IntegritySeverity
  message        String
  metadataJson   Json?
  occurredAt     DateTime
  createdAt      DateTime           @default(now())
  resolvedAt     DateTime?
  resolvedById   String?
  resolvedBy     User?              @relation("IntegrityEventResolver", fields: [resolvedById], references: [id])
  resolutionNote String?
  // On-Device AI Camera Integrity Detection v1 — Evidence Frames
  // (additive, opt-in). See docs/on-device-ai-integrity-detection-v1.md.
  // At most one per event in v1 (enforced by @unique on the asset's
  // integrityEventId below).
  evidenceAsset  IntegrityEvidenceAsset?

  // Exam Design Policy + Evidence Review v1 (additive) — see
  // docs/evidence-review-workflow-v1.md. The old resolvedAt/resolvedById/
  // resolutionNote above predate this feature and represent a single
  // resolved/unresolved boolean — kept exactly as-is, still written by
  // the legacy POST .../resolve route for backward compatibility (which
  // also now sets reviewStatus below to keep both views consistent).
  // reviewStatus is the new 5-state workflow field; validated string, not
  // a Prisma enum, following the SubmissionSimilarityAnalysis convention
  // — see src/lib/integrityReview.ts. reviewedAt/reviewedById/reviewNote
  // are new, separate from the legacy trio above, because "reviewed — no
  // concern" is not the same fact as "resolved".
  reviewStatus  String    @default("NEEDS_REVIEW") // NEEDS_REVIEW | REVIEWED_NO_CONCERN | REVIEWED_CONCERN_REMAINS | ESCALATED | RESOLVED
  reviewedAt    DateTime?
  reviewedById  String?
  reviewedBy    User?     @relation("IntegrityEventReviewer", fields: [reviewedById], references: [id])
  reviewNote    String?

  comments      IntegrityReviewComment[]
  statusHistory IntegrityReviewStatusHistory[]

  @@index([submissionId])
  @@index([examId])
  @@index([studentId])
  @@index([eventType])
  @@index([severity])
  @@index([occurredAt])
  @@index([reviewStatus])
}

// Exam Design Policy + Evidence Review v1 (additive) — see
// docs/evidence-review-workflow-v1.md. A freeform reviewer comment on
// one integrity event (optionally scoped to a specific evidence frame).
// Comments are immutable in practice — the API never exposes an edit or
// delete action, only create — updatedAt exists purely for Prisma's
// @updatedAt convention and is expected to always equal createdAt.
// authorRole/commentType are always derived server-side from the
// authenticated session, never accepted from the client (see
// docs/evidence-review-workflow-v1.md, "Reviewer identity"). This repo
// has no separate marker role/assignment — see
// docs/course-enrolment-and-exam-assignment.md and prisma/schema.prisma's
// Role enum — so commentType is REVIEWER_COMMENT for a PLATFORM_ADMIN or
// LECTURER_COMMENT for an actual LECTURER; MARKER_COMMENT is defined for
// forward-compatibility only and is never produced by any route today.
model IntegrityReviewComment {
  id               String                  @id @default(cuid())
  integrityEventId String
  integrityEvent   IntegrityEvent          @relation(fields: [integrityEventId], references: [id], onDelete: Cascade)
  evidenceAssetId  String?
  evidenceAsset    IntegrityEvidenceAsset? @relation(fields: [evidenceAssetId], references: [id], onDelete: SetNull)
  submissionId     String
  submission       Submission              @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  authorId         String
  author           User                    @relation("IntegrityReviewCommentAuthor", fields: [authorId], references: [id])
  authorRole       String // "LECTURER" | "PLATFORM_ADMIN" — server-derived, never client-supplied
  commentType      String // REVIEWER_COMMENT | LECTURER_COMMENT | MARKER_COMMENT | DECISION_NOTE
  comment          String
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([integrityEventId])
  @@index([submissionId])
  @@index([evidenceAssetId])
}

// Exam Design Policy + Evidence Review v1 (additive) — see
// docs/evidence-review-workflow-v1.md. One immutable row per status
// transition — created on EVERY reviewStatus change (including the
// initial implicit NEEDS_REVIEW is never written here; only actual
// transitions are). Never updated or deleted by any route — this is the
// audit-grade history a lecturer sees in the UI, distinct from
// PlatformAuditLog (which is the platform-wide operational audit trail).
model IntegrityReviewStatusHistory {
  id               String         @id @default(cuid())
  integrityEventId String
  integrityEvent   IntegrityEvent @relation(fields: [integrityEventId], references: [id], onDelete: Cascade)
  submissionId     String
  submission       Submission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fromStatus       String?
  toStatus         String
  changedById      String
  changedBy        User           @relation("IntegrityReviewStatusChanger", fields: [changedById], references: [id])
  changedByRole    String
  reason           String?
  createdAt        DateTime       @default(now())

  @@index([integrityEventId])
  @@index([submissionId])
}

// Course, Enrolment, Exam Assignment, Scheduling v1 — see
// docs/course-enrolment-and-exam-assignment.md. Course is the academic
// grouping inside an Institution (the hard tenancy boundary). It does not
// replace Institution-level isolation — every Course belongs to exactly
// one Institution, and cross-institution access is still governed by
// institutionScope.ts exactly as before.
model Course {
  id            String             @id @default(cuid())
  institutionId String
  institution   Institution        @relation(fields: [institutionId], references: [id])
  name          String
  code          String
  description   String?
  active        Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  enrollments   CourseEnrollment[]
  exams         Exam[]
  // Canvas/LTI mapping hook (v1 foundation only) — see
  // docs/course-enrolment-and-exam-assignment.md Part 7. Exam-level
  // Canvas mapping already exists via LtiExamLink; these are the
  // course-level equivalent, added additively and unused by existing
  // LTI code paths so nothing breaks if left unset.
  canvasCourseId String?
  ltiPlatformId  String?

  @@unique([institutionId, code])
  @@index([institutionId])
}

model CourseEnrollment {
  id        String     @id @default(cuid())
  courseId  String
  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      CourseRole
  createdAt DateTime   @default(now())

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
}

// Selected-student exam assignment — only meaningful when the owning
// Exam has assignmentMode: SELECTED_STUDENTS. Ignored otherwise.
model ExamAssignment {
  id        String   @id @default(cuid())
  examId    String
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([examId, studentId])
  @@index([examId])
  @@index([studentId])
}

model LtiPlatform {
  id            String       @id @default(cuid())
  issuer        String       @unique
  clientId      String
  authEndpoint  String
  tokenEndpoint String
  jwksUrl       String
  deploymentId  String
  createdAt     DateTime     @default(now())
  sessions      LtiSession[]
  examLinks     LtiExamLink[]
  launches      LtiLaunch[]
  // Multi-Tenant Architecture v1 (additive, nullable) — one platform
  // (Canvas instance) belongs to exactly one institution.
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id])
}

model LtiSession {
  id         String      @id @default(cuid())
  platform   LtiPlatform @relation(fields: [platformId], references: [id])
  platformId String
  nonce      String      @unique
  state      String      @unique
  expiresAt  DateTime
  consumed   Boolean     @default(false)
  createdAt  DateTime    @default(now())
}

model LtiExamLink {
  id                 String   @id @default(cuid())
  examId             String
  exam               Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  platformId         String
  platform           LtiPlatform @relation(fields: [platformId], references: [id])
  resourceLinkId     String
  canvasCourseId     String?
  canvasAssignmentId String?
  label              String?
  createdAt          DateTime @default(now())

  @@unique([platformId, resourceLinkId])
  @@index([examId])
}

model LtiLaunch {
  id                 String   @id @default(cuid())
  platformId         String
  // Relation field added so launches can be scoped to their platform's
  // institution (see docs/multi-tenant-migration.md). This does not add a
  // database column — platformId already existed; this only adds the
  // Prisma-level join, matching the existing pattern on LtiSession/LtiExamLink.
  platform           LtiPlatform @relation(fields: [platformId], references: [id])
  canvasUserId       String
  canvasCourseId     String
  canvasAssignmentId String?
  lineitems          String?
  sourcedid          String?
  examId             String?
  submissionId       String?
  // --- AGS hardening (additive) ---
  deploymentId       String?
  resourceLinkId     String?
  lineitemUrl        String?
  lineitemsUrl       String?
  agsScopeJson       Json?
  // Raw verified launch claims, kept server-side only for debugging.
  // Never returned to students or in any client-facing API response.
  launchClaimsJson   Json?
  launchRole         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  gradePassbacks     CanvasGradePassback[]
}

model CanvasGradePassback {
  id                 String               @id @default(cuid())
  submissionId       String               @unique
  submission         Submission           @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  ltiLaunchId        String?
  ltiLaunch          LtiLaunch?           @relation(fields: [ltiLaunchId], references: [id])
  status             CanvasPassbackStatus @default(NOT_READY)
  scoreGiven         Float?
  scoreMaximum       Float?
  scorePct           Float?
  attemptedAt        DateTime?
  sentAt             DateTime?
  errorMessage       String?
  canvasResponseJson Json?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([status])
}

// Academic Integrity Network Evidence v1 — see
// docs/network-evidence-and-ip-location.md. Records IP address,
// approximate IP-based location, and browser/device metadata at exam
// open and exam submit. Evidence-only: never blocks a student, never
// auto-determines misconduct.
model NetworkEvidence {
  id               String   @id @default(cuid())
  submissionId     String
  submission       Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  examId           String
  exam             Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId        String
  student          User     @relation("NetworkEvidenceStudent", fields: [studentId], references: [id])
  institutionId    String
  // source: EXAM_START captured at new submission creation;
  // EXAM_SUBMIT captured on final submit.
  source           String
  ipAddress        String?
  ipHash           String?
  userAgent        String?
  browserName      String?
  osName           String?
  deviceType       String?
  country          String?
  region           String?
  city             String?
  timezone         String?
  locationAccuracy String   @default("UNAVAILABLE")
  vpnOrProxySignal Boolean  @default(false)
  networkChanged   Boolean  @default(false)
  metadata         Json?
  createdAt        DateTime @default(now())

  @@index([submissionId])
  @@index([examId])
  @@index([studentId])
  @@index([institutionId])
  @@index([createdAt])
}

// On-Device AI Camera Integrity Detection v1 — Evidence Frames (additive,
// opt-in) — see docs/on-device-ai-integrity-detection-v1.md. A single,
// privacy-minimised webcam still frame, captured only when the exam's
// secureSettings.captureAiViolationEvidence is enabled AND a
// POSSIBLE_PHONE_VISIBLE or POSSIBLE_SECOND_PERSON_VISIBLE event is
// backend-logged — never on every overlay redisplay, never a video,
// never the exam screen/desktop, never used for face recognition or any
// biometric identification. Image bytes are never stored inline here or
// in IntegrityEvent.metadataJson — only a storageKey pointing into
// src/lib/evidenceStorage.ts, resolved server-side only through the
// authenticated, audited GET /api/integrity-evidence/[evidenceAssetId]
// route. institutionId is a plain scoping column, not a navigated
// relation — mirrors NetworkEvidence.institutionId above.
model IntegrityEvidenceAsset {
  id               String                 @id @default(cuid())
  integrityEventId String                 @unique
  integrityEvent   IntegrityEvent         @relation(fields: [integrityEventId], references: [id], onDelete: Cascade)
  submissionId     String
  submission       Submission             @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  examId           String
  exam             Exam                   @relation(fields: [examId], references: [id], onDelete: Cascade)
  institutionId    String

  kind      String // "AI_CAMERA_EVIDENCE_FRAME" in v1 — see src/lib/aiCameraEvidenceFrame.ts
  eventType String // "POSSIBLE_PHONE_VISIBLE" | "POSSIBLE_SECOND_PERSON_VISIBLE" in v1

  storageProvider String // "local_dev" | "vercel_blob" | "supabase_storage" | "s3" — see src/lib/evidenceStorage.ts
  storageKey      String // Opaque; never returned to any client — resolved server-side only.
  contentType     String
  byteSize        Int
  sha256          String?

  width         Int?
  height        Int?
  redactionMode String   @default("LOW_RES_FULL_FRAME")
  capturedAt    DateTime @default(now())

  createdAt DateTime @default(now())

  // Exam Design Policy + Evidence Review v1 (additive) — see
  // docs/evidence-review-workflow-v1.md. A comment may optionally be
  // scoped to this specific evidence frame rather than the event as a
  // whole.
  reviewComments IntegrityReviewComment[]

  @@index([integrityEventId])
  @@index([submissionId])
  @@index([examId])
  @@index([institutionId])
  @@index([capturedAt])
}

// AI-Use Answer Review v1 (additive) — see docs/ai-use-answer-review-v1.md.
// This is NOT an AI detector: every row here is an explainable REVIEW
// SIGNAL about observable answer characteristics for a human lecturer to
// weigh — never a claim that an answer was written by AI, never an
// automatic misconduct finding, never a grade input. Status/level/type/
// review-status fields are plain validated String columns (not Prisma
// enums), following the SubmissionSimilarityAnalysis convention — see
// src/lib/aiUseReview.ts for the validators. One reusable row per
// submission (a re-run replaces its prior signals, mirroring
// runSimilarityAnalysisForExam's reuse pattern).
model AiUseReviewAnalysis {
  id           String     @id @default(cuid())
  submissionId String     @unique
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  examId       String
  exam         Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  status       String     @default("PENDING") // PENDING | PROCESSING | COMPLETE | FAILED | NOT_CONFIGURED
  overallSignalLevel String @default("NONE") // NONE | LOW | MEDIUM | HIGH
  // "deterministic" (Layer A only) or "anthropic" (Layer A + optional
  // Layer B) — never a claim about who/what "detected" anything.
  provider        String
  modelIdentifier String?
  algorithmVersion String
  analysedAt      DateTime?
  requestedById   String
  requestedBy     User      @relation("AiUseReviewRequestedBy", fields: [requestedById], references: [id])
  failureCode     String?
  recommendation  String    @default("NO_IMMEDIATE_ACTION") // NO_IMMEDIATE_ACTION | LECTURER_REVIEW_RECOMMENDED | ORAL_VERIFICATION_RECOMMENDED
  reasonCodesJson Json?
  summaryJson     Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  signals         AiUseReviewSignal[]

  @@index([examId])
  @@index([status])
}

// One explainable signal produced by one analysis run — see
// docs/ai-use-answer-review-v1.md. evidenceJson holds only short,
// explainable observations (never the full answer text, never a hidden
// AI-generated "chain of thought"). questionId is the question the
// signal concerns; answerId is nullable because a signal may be derived
// from comparing multiple answers (e.g. writing-style consistency) with
// no single "the" answer it belongs to.
model AiUseReviewSignal {
  id           String              @id @default(cuid())
  analysisId   String
  analysis     AiUseReviewAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question            @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerId     String?
  answer       Answer?             @relation(fields: [answerId], references: [id], onDelete: SetNull)
  signalType   String // WEAK_SCENARIO_GROUNDING | GENERIC_RESPONSE | STYLE_INCONSISTENCY | UNSUPPORTED_SPECIFIC_CLAIMS | REQUIRED_CONCEPTS_MISSING | POLISHED_BUT_SHALLOW_RESPONSE | GENERATED_RESPONSE_META_LANGUAGE
  signalLevel  String // NONE | LOW | MEDIUM | HIGH
  explanation  String
  evidenceJson Json?
  reviewStatus String    @default("NEEDS_REVIEW") // NEEDS_REVIEW | REVIEWED_NO_CONCERN | REVIEWED_CONCERN_REMAINS | ESCALATED | RESOLVED
  reviewedAt   DateTime?
  reviewedById String?
  reviewedBy   User?     @relation("AiUseReviewSignalReviewer", fields: [reviewedById], references: [id])
  reviewNote   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([analysisId])
  @@index([questionId])
  @@index([answerId])
  @@index([reviewStatus])
}

// Exam Session Binding + Time Anomaly Review v1 (additive) — see
// docs/exam-session-binding-v1.md and docs/time-anomaly-review-v1.md.
// THIS PRODUCES LECTURER REVIEW SIGNALS ONLY — never an automatic
// misconduct finding, never a grade input, never an automatic attempt
// termination. Only HMAC hashes, coarse categories, and IP network
// PREFIXES are ever stored — never raw IP addresses, raw tokens, or raw
// user-agent strings needed for display (userAgentHash exists purely for
// server-side comparison). Status/type/level/review-status fields are
// plain validated String columns (not Prisma enums), following the
// SubmissionSimilarityAnalysis convention — see src/lib/sessionBinding.ts
// and src/lib/sessionIntegrity.ts for the validators.
model ExamAttemptSession {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation("ExamAttemptSessionUser", fields: [userId], references: [id], onDelete: Cascade)

  // Server-issued, HMAC-hashed only — the raw token lives solely in a
  // Secure/HttpOnly/SameSite cookie on the student's browser, never in
  // the database and never returned by any API response.
  browserSessionTokenHash String
  deviceTokenHash         String

  // Supporting signal only — never the primary binding mechanism. See
  // Part 2 (allowed low-entropy inputs only: browser/OS family, device
  // category, accepted language, timezone, screen-size bucket).
  coarseFingerprintHash String?
  userAgentHash         String?
  browserFamily         String?
  operatingSystemFamily String?
  deviceCategory        String?

  // Network prefix only (never a raw IP) — /24 for IPv4, /48 for IPv6,
  // HMAC-hashed. See src/lib/sessionBinding.ts.
  ipPrefixHash String?
  ipVersion    String? // "v4" | "v6"

  // granted | denied | prompt | unavailable | unknown — Permissions API
  // absence is "unknown", never treated as a violation.
  cameraPermissionState String @default("unknown")

  startedAt DateTime  @default(now())
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  endedAt     DateTime?
  status      String    @default("ACTIVE") // ACTIVE | STALE | ENDED | REPLACED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  signals SessionIntegritySignal[]
  activityEvents AnswerActivityEvent[]

  @@index([submissionId])
  @@index([userId])
  @@index([status])
  @@index([lastSeenAt])
  @@index([deviceTokenHash])
}

// One explainable session-binding review signal — see
// docs/exam-session-binding-v1.md. examAttemptSessionId is nullable
// because a signal (e.g. CONCURRENT_ACTIVE_SESSIONS) may concern more
// than one session with no single "the" session it belongs to.
model SessionIntegritySignal {
  id                   String              @id @default(cuid())
  submissionId         String
  submission           Submission          @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  examAttemptSessionId String?
  examAttemptSession   ExamAttemptSession? @relation(fields: [examAttemptSessionId], references: [id], onDelete: SetNull)

  signalType   String // CONCURRENT_ACTIVE_SESSIONS | DEVICE_TOKEN_CHANGED | COARSE_DEVICE_PROFILE_CHANGED | USER_AGENT_CHANGED | NETWORK_PREFIX_CHANGED | REPEATED_NETWORK_CHANGES | CAMERA_PERMISSION_CHANGED | SESSION_TOKEN_MISMATCH | SESSION_RESTARTED
  signalLevel  String // LOW | MEDIUM | HIGH
  explanation  String
  evidenceJson Json?

  reviewStatus String    @default("NEEDS_REVIEW") // NEEDS_REVIEW | REVIEWED_NO_CONCERN | REVIEWED_CONCERN_REMAINS | ESCALATED | RESOLVED
  reviewedAt   DateTime?
  reviewedById String?
  reviewedBy   User?     @relation("SessionIntegritySignalReviewer", fields: [reviewedById], references: [id])
  reviewNote   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([submissionId])
  @@index([examAttemptSessionId])
  @@index([reviewStatus])
}

// Coarse activity telemetry — see docs/exam-session-binding-v1.md. Never
// stores keystrokes, clipboard content, or a duplicate of the full
// answer text: only a length, an HMAC hash of the normalised response
// (for change-detection, not reconstruction), and a length delta.
// previousEventId is an advisory pointer only (no FK) to the prior
// ANSWER_SAVED event for the same question, used to compute the delta —
// deliberately not a Prisma relation, since it is never used for
// cascade behaviour. serverReceivedAt is authoritative; clientElapsedMs
// is supplementary only and never overrides it.
model AnswerActivityEvent {
  id                   String              @id @default(cuid())
  submissionId         String
  submission           Submission          @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId           String?
  question             Question?           @relation(fields: [questionId], references: [id], onDelete: SetNull)
  examAttemptSessionId String?
  examAttemptSession   ExamAttemptSession? @relation(fields: [examAttemptSessionId], references: [id], onDelete: SetNull)

  eventType String // ATTEMPT_STARTED | QUESTION_OPENED | ANSWER_SAVED | QUESTION_NAVIGATED | HEARTBEAT | PAGE_HIDDEN | PAGE_VISIBLE | ATTEMPT_SUBMITTED

  serverReceivedAt  DateTime @default(now())
  clientElapsedMs   Int?
  questionIndex     Int?
  responseLength    Int?
  responseHash      String?
  responseLengthDelta Int?
  previousEventId   String?
  metadataJson      Json?

  createdAt DateTime @default(now())

  @@index([submissionId])
  @@index([questionId])
  @@index([examAttemptSessionId])
  @@index([eventType])
  @@index([serverReceivedAt])
}

// One reusable timing-analysis row per submission — mirrors
// AiUseReviewAnalysis's shape/reuse pattern. Added beyond the models
// Part 3 enumerated because Part 13's separate
// PATCH /api/lecturer/timing-signals/[signalId]/review route (distinct
// from session-signals) requires its own signal storage — see
// docs/time-anomaly-review-v1.md.
model TimingAnalysis {
  id           String     @id @default(cuid())
  submissionId String     @unique
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  examId       String
  exam         Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)

  status             String    @default("PENDING") // PENDING | PROCESSING | COMPLETE | FAILED
  overallSignalLevel String    @default("NONE") // NONE | LOW | MEDIUM | HIGH
  algorithmVersion   String
  analysedAt         DateTime?
  requestedById      String
  requestedBy        User      @relation("TimingAnalysisRequestedBy", fields: [requestedById], references: [id])

  recommendation  String @default("NO_IMMEDIATE_ACTION") // NO_IMMEDIATE_ACTION | LECTURER_REVIEW_RECOMMENDED | ORAL_VERIFICATION_RECOMMENDED | ESCALATION_RECOMMENDED
  reasonCodesJson Json?
  summaryJson     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  signals TimingIntegritySignal[]

  @@index([examId])
  @@index([status])
}

model TimingIntegritySignal {
  id         String         @id @default(cuid())
  analysisId String
  analysis   TimingAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  signalType   String // EXTREMELY_FAST_ATTEMPT | RAPID_MULTI_QUESTION_COMPLETION | RAPID_LARGE_RESPONSE_APPEARANCE | LONG_INACTIVITY_THEN_LARGE_RESPONSE | VERY_FAST_CORRECT_RESPONSE_PATTERN | SIMILAR_RESPONSE_TIMING_PATTERN | ABRUPT_ACTIVITY_BURST | INSUFFICIENT_TIMING_DATA
  signalLevel  String // LOW | MEDIUM | HIGH
  explanation  String
  evidenceJson Json?

  reviewStatus String    @default("NEEDS_REVIEW")
  reviewedAt   DateTime?
  reviewedById String?
  reviewedBy   User?     @relation("TimingIntegritySignalReviewer", fields: [reviewedById], references: [id])
  reviewNote   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([analysisId])
  @@index([reviewStatus])
}

model QuestionBank {
  id          String         @id @default(cuid())
  lecturerId  String
  title       String
  description String?
  subject     String?
  courseCode  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  lecturer    User           @relation(fields: [lecturerId], references: [id])
  questions   BankQuestion[]

  @@index([lecturerId])
}

model BankQuestion {
  id            String       @id @default(cuid())
  bankId        String
  type          String
  text          String
  optionsJson   String?
  correctAnswer String?
  sampleAnswer  String?
  points        Int          @default(1)
  difficulty    String?
  topic         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  bank          QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@index([bankId])
  @@index([type])
  @@index([topic])
  @@index([difficulty])
}

// Controlled AI Brainstorming Assistance v1 (additive, opt-in) — see
// docs/controlled-ai-brainstorming-assistance-v1.md. One row per student
// request. This is an AUDITABLE RECORD OF AN ALLOWED ASSESSMENT RESOURCE,
// not an integrity-violation log — status/riskCodes describe the
// generator/verifier pipeline's own internal decision-making, never a
// finding about the student. `status`/`riskCodes` are validated strings,
// not Prisma enums, following the SubmissionSimilarityAnalysis/
// IntegrityEvidenceAsset convention (see src/lib/aiAssistancePolicy.ts for
// validation). `approvedResponse` is null whenever the request was
// blocked pre-generation (status "BLOCKED") — the verifier's rejected
// candidate text is NEVER stored anywhere, on any status, since it may
// contain prohibited answer content (see src/lib/aiAssistanceRunner.ts).
model AiAssistanceInteraction {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  examId       String
  studentId    String
  student      User       @relation(fields: [studentId], references: [id])

  studentPrompt    String
  // Null when status is "BLOCKED" (classifier rejected the request before
  // any generation/verification ran) — see status below.
  approvedResponse String?

  // BLOCKED (classifier rejected the request pre-generation) |
  // APPROVED (first candidate passed verification) |
  // REGENERATED_APPROVED (first candidate failed verification, the
  //   stricter regeneration passed) |
  // FALLBACK (both attempts failed verification; the deterministic safe
  //   Socratic fallback was returned instead of any generated text)
  status String

  promptNumberForQuestion Int
  promptNumberForAttempt  Int
  policyVersion           String

  // Structured verifier output (Part 8) — riskCodesJson is a JSON array of
  // strings (DIRECT_ANSWER, NEAR_COMPLETE_ANSWER, etc; empty array for a
  // BLOCKED or cleanly-APPROVED interaction with nothing flagged).
  riskCodesJson        Json?
  riskScore            Float @default(0)
  cumulativeRiskScore  Float @default(0)
  specificityLevel     Int   @default(0)

  providerModel String?
  latencyMs     Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([submissionId])
  @@index([submissionId, questionId])
  @@index([examId])
  @@index([studentId])
  @@index([submissionId, createdAt])
}
