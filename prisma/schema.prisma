generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  LECTURER
  STUDENT
  PLATFORM_ADMIN
}

enum QuestionType {
  MULTIPLE_CHOICE
  SHORT_ANSWER
  ESSAY
}

enum SubmissionStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum IntegrityEventType {
  FULLSCREEN_EXIT
  WINDOW_BLUR
  WINDOW_FOCUS_RETURN
  COPY_ATTEMPT
  PASTE_ATTEMPT
  RIGHT_CLICK_ATTEMPT
  DEVTOOLS_SUSPECTED
  NETWORK_OFFLINE
  NETWORK_ONLINE
  AUTOSAVE_FAILED
  TIMER_EXPIRED
  SUBMIT_AFTER_DEADLINE
  MANUAL_WARNING
  // Camera Monitoring v1 (additive — see docs/secure-exam-threat-model.md)
  CAMERA_PERMISSION_GRANTED
  CAMERA_PERMISSION_DENIED
  CAMERA_STARTED
  CAMERA_STOPPED
  CAMERA_UNAVAILABLE
  CAMERA_HEARTBEAT_MISSED
  CAMERA_PRECHECK_FAILED
  // Browser-Level Friction v1 (additive)
  KEYBOARD_SHORTCUT_BLOCKED
  FULLSCREEN_FORCED_RETURN
}

enum IntegritySeverity {
  INFO
  LOW
  MEDIUM
  HIGH
}

enum CanvasPassbackStatus {
  NOT_READY
  PENDING
  SENT
  FAILED
  SKIPPED
}

// Multi-Tenant Architecture v1 — see docs/multi-tenant-migration.md.
model Institution {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  domain       String?
  plan         String        @default("pilot")
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  users        User[]
  exams        Exam[]
  ltiPlatforms LtiPlatform[]
}

model User {
  id                String           @id @default(cuid())
  name              String
  email             String           @unique
  passwordHash      String
  role              Role
  createdAt         DateTime         @default(now())
  examsCreated      Exam[]           @relation("ExamCreator")
  submissions       Submission[]
  integrityEvents   IntegrityEvent[] @relation("IntegrityEventStudent")
  resolvedEvents     IntegrityEvent[] @relation("IntegrityEventResolver")
  // canvasUserId is unique per institution, not globally — a self-hosted
  // Canvas instance at a different institution could otherwise collide
  // with another institution's user id. See docs/multi-tenant-migration.md.
  canvasUserId      String?
  canvasCourseIds   String[]         @default([])
  questionBanks     QuestionBank[]
  // Multi-Tenant Architecture v1 (additive, nullable — see
  // docs/multi-tenant-migration.md). Nullable at the DB level; application
  // code treats it as required via src/lib/institutionScope.ts.
  institutionId     String?
  institution       Institution?     @relation(fields: [institutionId], references: [id])

  @@unique([institutionId, canvasUserId])
  @@index([institutionId])
}

model Exam {
  id              String           @id @default(cuid())
  title           String
  description     String?
  durationMins    Int
  published       Boolean          @default(false)
  startsAt        DateTime?
  endsAt          DateTime?
  createdById     String
  createdBy       User             @relation("ExamCreator", fields: [createdById], references: [id])
  questions       Question[]
  submissions     Submission[]
  integrityEvents IntegrityEvent[]
  ltiExamLinks    LtiExamLink[]
  // Secure Exam Mode v1 settings (see src/lib/secureExam.ts for shape/defaults).
  // A single JSON column rather than ~10 booleans/ints, since this app has no
  // other multi-flag settings model and these are read/written together.
  secureSettings  Json?
  createdAt       DateTime         @default(now())
  // Multi-Tenant Architecture v1 (additive, nullable) — see
  // docs/multi-tenant-migration.md.
  institutionId   String?
  institution     Institution?     @relation(fields: [institutionId], references: [id])

  @@index([institutionId])
}

model Question {
  id            String       @id @default(cuid())
  examId        String
  exam          Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  type          QuestionType
  text          String
  options       Json?
  correctAnswer String?
  points        Int          @default(1)
  order         Int          @default(0)
  answers       Answer[]
}

model Submission {
  id          String           @id @default(cuid())
  examId      String
  exam        Exam             @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId   String
  student     User             @relation(fields: [studentId], references: [id])
  status      SubmissionStatus @default(IN_PROGRESS)
  startedAt   DateTime         @default(now())
  submittedAt DateTime?
  gradedAt    DateTime?
  totalScore  Int?
  answers     Answer[]
  integrityEvents IntegrityEvent[]
  gradePassback   CanvasGradePassback?

  @@unique([examId, studentId])
}

model Answer {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  response          String?
  score             Int?
  feedback          String?
  isCorrect         Boolean?
  timeSpentSeconds  Int?
  aiDraftScore      Float?
  aiReasoning       String?
  aiGradedAt        DateTime?

  @@unique([submissionId, questionId])
}

model IntegrityEvent {
  id             String             @id @default(cuid())
  submissionId   String
  submission     Submission         @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  examId         String
  exam           Exam               @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId      String
  student        User               @relation("IntegrityEventStudent", fields: [studentId], references: [id])
  eventType      IntegrityEventType
  severity       IntegritySeverity
  message        String
  metadataJson   Json?
  occurredAt     DateTime
  createdAt      DateTime           @default(now())
  resolvedAt     DateTime?
  resolvedById   String?
  resolvedBy     User?              @relation("IntegrityEventResolver", fields: [resolvedById], references: [id])
  resolutionNote String?

  @@index([submissionId])
  @@index([examId])
  @@index([studentId])
  @@index([eventType])
  @@index([severity])
  @@index([occurredAt])
}

model LtiPlatform {
  id            String       @id @default(cuid())
  issuer        String       @unique
  clientId      String
  authEndpoint  String
  tokenEndpoint String
  jwksUrl       String
  deploymentId  String
  createdAt     DateTime     @default(now())
  sessions      LtiSession[]
  examLinks     LtiExamLink[]
  launches      LtiLaunch[]
  // Multi-Tenant Architecture v1 (additive, nullable) — one platform
  // (Canvas instance) belongs to exactly one institution.
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id])
}

model LtiSession {
  id         String      @id @default(cuid())
  platform   LtiPlatform @relation(fields: [platformId], references: [id])
  platformId String
  nonce      String      @unique
  state      String      @unique
  expiresAt  DateTime
  consumed   Boolean     @default(false)
  createdAt  DateTime    @default(now())
}

model LtiExamLink {
  id                 String   @id @default(cuid())
  examId             String
  exam               Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  platformId         String
  platform           LtiPlatform @relation(fields: [platformId], references: [id])
  resourceLinkId     String
  canvasCourseId     String?
  canvasAssignmentId String?
  label              String?
  createdAt          DateTime @default(now())

  @@unique([platformId, resourceLinkId])
  @@index([examId])
}

model LtiLaunch {
  id                 String   @id @default(cuid())
  platformId         String
  // Relation field added so launches can be scoped to their platform's
  // institution (see docs/multi-tenant-migration.md). This does not add a
  // database column — platformId already existed; this only adds the
  // Prisma-level join, matching the existing pattern on LtiSession/LtiExamLink.
  platform           LtiPlatform @relation(fields: [platformId], references: [id])
  canvasUserId       String
  canvasCourseId     String
  canvasAssignmentId String?
  lineitems          String?
  sourcedid          String?
  examId             String?
  submissionId       String?
  // --- AGS hardening (additive) ---
  deploymentId       String?
  resourceLinkId     String?
  lineitemUrl        String?
  lineitemsUrl       String?
  agsScopeJson       Json?
  // Raw verified launch claims, kept server-side only for debugging.
  // Never returned to students or in any client-facing API response.
  launchClaimsJson   Json?
  launchRole         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  gradePassbacks     CanvasGradePassback[]
}

model CanvasGradePassback {
  id                 String               @id @default(cuid())
  submissionId       String               @unique
  submission         Submission           @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  ltiLaunchId        String?
  ltiLaunch          LtiLaunch?           @relation(fields: [ltiLaunchId], references: [id])
  status             CanvasPassbackStatus @default(NOT_READY)
  scoreGiven         Float?
  scoreMaximum       Float?
  scorePct           Float?
  attemptedAt        DateTime?
  sentAt             DateTime?
  errorMessage       String?
  canvasResponseJson Json?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([status])
}

model QuestionBank {
  id          String         @id @default(cuid())
  lecturerId  String
  title       String
  description String?
  subject     String?
  courseCode  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  lecturer    User           @relation(fields: [lecturerId], references: [id])
  questions   BankQuestion[]

  @@index([lecturerId])
}

model BankQuestion {
  id            String       @id @default(cuid())
  bankId        String
  type          String
  text          String
  optionsJson   String?
  correctAnswer String?
  sampleAnswer  String?
  points        Int          @default(1)
  difficulty    String?
  topic         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  bank          QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@index([bankId])
  @@index([type])
  @@index([topic])
  @@index([difficulty])
}
