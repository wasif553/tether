# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://user:password@localhost:5432/safe_exam_system?schema=public"

# Only needed if running `prisma migrate dev` against a database that
# requires a separate shadow database.
SHADOW_DATABASE_URL=

# NextAuth session signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET=

# --- LTI 1.3 (Canvas) ---
# Values from the Canvas Developer Key created for this tool.
LTI_CLIENT_ID=
LTI_DEPLOYMENT_ID=

# Canvas platform endpoints. These defaults work for canvas.instructure.com;
# self-hosted Canvas instances will have different URLs.
LTI_PLATFORM_ISSUER=https://canvas.instructure.com
LTI_PLATFORM_OIDC_AUTH=https://sso.canvaslms.com/api/lti/authorize_redirect
LTI_PLATFORM_JWKS=https://sso.canvaslms.com/api/lti/security/jwks

# RSA keypair used to sign/verify LTI JWTs. Generate with:
#   openssl genrsa -out lti_private.pem 2048
#   openssl rsa -in lti_private.pem -pubout -out lti_public.pem
# Paste the PEM contents below, preserving newlines as \n if kept on one line.
LTI_PRIVATE_KEY=
LTI_PUBLIC_KEY=

# Public base URL of this app, used to build LTI redirect/launch URLs.
APP_URL=http://localhost:3000
