# =============================================================================
# REQUIRED — core standalone secure exam platform
# =============================================================================

# PostgreSQL connection string used by Prisma. For Supabase, use the
# "Connection pooling" string (port 6543) for this value on Vercel — see
# docs/deployment-vercel-supabase.md.
DATABASE_URL="postgresql://user:password@localhost:5432/safe_exam_system?schema=public"

# NextAuth (v5) session signing secret. This app reads AUTH_SECRET — it does
# NOT read NEXTAUTH_SECRET. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Public base URL of this app, used to build LTI redirect/launch URLs and
# (recommended) for NextAuth's own callback URL construction.
# The dev/start scripts run this app on port 3001 locally.
# This app does NOT currently read AUTH_URL/NEXTAUTH_URL or
# NEXT_PUBLIC_APP_URL from code — only APP_URL is consumed. They're listed
# here for forward-compatibility / convention; set APP_URL as the source of
# truth.
APP_URL=http://localhost:3001
# NEXT_PUBLIC_APP_URL=http://localhost:3001

# =============================================================================
# LOCAL DEVELOPMENT ONLY
# =============================================================================

# Only needed if running `prisma migrate dev` against a database that
# requires a separate shadow database. Not used by `prisma db push` or in
# production.
SHADOW_DATABASE_URL=

# =============================================================================
# OPTIONAL — Canvas / LTI 1.3 module (app works fully without this)
# =============================================================================

# Values from the Canvas Developer Key created for this tool.
LTI_CLIENT_ID=
LTI_DEPLOYMENT_ID=

# Canvas platform endpoints. These defaults work for canvas.instructure.com;
# self-hosted Canvas instances will have different URLs.
LTI_PLATFORM_ISSUER=https://canvas.instructure.com
LTI_PLATFORM_OIDC_AUTH=https://sso.canvaslms.com/api/lti/authorize_redirect
LTI_PLATFORM_JWKS=https://sso.canvaslms.com/api/lti/security/jwks
LTI_TOKEN_ENDPOINT=https://sso.canvaslms.com/ids/oidc/token

# RSA keypair used to sign/verify LTI JWTs. Three ways to provide each key —
# only one is needed, checked in this priority order: *_B64, then *_PATH,
# then the raw multiline var. See docs/deployment-vercel-supabase.md for
# generation instructions.
#
# Recommended for Vercel/deployment (base64-encoded, single line, avoids
# newline-mangling in dashboard env var UIs):
LTI_PRIVATE_KEY_B64=
LTI_PUBLIC_KEY_B64=
#
# Local development only — path to a PEM file on disk:
LTI_PRIVATE_KEY_PATH=
LTI_PUBLIC_KEY_PATH=
#
# Legacy/local fallback — raw PEM contents, preserving newlines as \n if kept
# on one line:
LTI_PRIVATE_KEY=
LTI_PUBLIC_KEY=

# Branding shown in the LTI tool config JSON (/api/lti/config). Optional —
# defaults are used if unset.
LTI_TOOL_NAME=
LTI_TOOL_DESCRIPTION=

# =============================================================================
# OPTIONAL — AI module (app works fully without this)
# =============================================================================

# Anthropic API key used for AI question generation and AI draft essay
# marking. Without it, those features return a safe "not configured" error;
# nothing else in the app is affected.
ANTHROPIC_API_KEY=
