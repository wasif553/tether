# =============================================================================
# REQUIRED — core standalone secure exam platform
# =============================================================================

# PostgreSQL connection string used by Prisma. For Supabase, use the
# "Connection pooling" string (port 6543) for this value on Vercel — see
# docs/deployment-vercel-supabase.md.
DATABASE_URL="postgresql://user:password@localhost:5432/safe_exam_system?schema=public"

# Max connections this app's in-process pg pool opens PER serverless
# invocation. Keep this low on Vercel (default: 3) — Vercel can run many
# concurrent invocations, each with its own pool, and a high per-instance
# max can exhaust Supabase's pooled connection limit under concurrent
# exam traffic. See docs/concurrent-exam-pilot-capacity.md.
DATABASE_POOL_MAX=3

# NextAuth (v5) session signing secret. This app reads AUTH_SECRET — it does
# NOT read NEXTAUTH_SECRET. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Public base URL of this app, used to build the Canvas-facing
# redirect_uri/target_link_uri in /api/lti/login and /api/lti/config (must
# match what's registered in Canvas's Developer Key). NOT used for
# internal, same-app navigation — e.g. /api/lti/launch's post-launch
# redirect derives its destination from the incoming request's own origin
# instead, specifically so it can never point at a stale/previous
# deployment URL after a redeploy.
# The dev/start scripts run this app on port 3001 locally.
# This app does NOT currently read AUTH_URL/NEXTAUTH_URL or
# NEXT_PUBLIC_APP_URL from code — only APP_URL is consumed. They're listed
# here for forward-compatibility / convention; set APP_URL as the source of
# truth.
APP_URL=http://localhost:3001
# NEXT_PUBLIC_APP_URL=http://localhost:3001

# =============================================================================
# LOCAL DEVELOPMENT ONLY
# =============================================================================

# Only needed if running `prisma migrate dev` against a database that
# requires a separate shadow database. Not used by `prisma db push` or in
# production.
SHADOW_DATABASE_URL=

# =============================================================================
# OPTIONAL — Canvas / LTI 1.3 module (app works fully without this)
# =============================================================================

# Values from the Canvas Developer Key created for this tool.
LTI_CLIENT_ID=
LTI_DEPLOYMENT_ID=

# Canvas platform endpoints. These defaults work for canvas.instructure.com;
# self-hosted Canvas instances will have different URLs.
LTI_PLATFORM_ISSUER=https://canvas.instructure.com
LTI_PLATFORM_OIDC_AUTH=https://sso.canvaslms.com/api/lti/authorize_redirect
LTI_PLATFORM_JWKS=https://sso.canvaslms.com/api/lti/security/jwks
LTI_TOKEN_ENDPOINT=https://sso.canvaslms.com/ids/oidc/token

# RSA keypair used to sign/verify LTI JWTs. Three ways to provide each key —
# only one is needed, checked in this priority order: *_B64, then *_PATH,
# then the raw multiline var. See docs/deployment-vercel-supabase.md for
# generation instructions.
#
# Recommended for Vercel/deployment (base64-encoded, single line, avoids
# newline-mangling in dashboard env var UIs):
LTI_PRIVATE_KEY_B64=
LTI_PUBLIC_KEY_B64=
#
# Local development only — path to a PEM file on disk:
LTI_PRIVATE_KEY_PATH=
LTI_PUBLIC_KEY_PATH=
#
# Legacy/local fallback — raw PEM contents, preserving newlines as \n if kept
# on one line:
LTI_PRIVATE_KEY=
LTI_PUBLIC_KEY=

# Branding shown in the LTI tool config JSON (/api/lti/config). Optional —
# defaults are used if unset.
LTI_TOOL_NAME=
LTI_TOOL_DESCRIPTION=

# =============================================================================
# OPTIONAL — platform admin seed (see docs/platform-admin-onboarding.md)
# =============================================================================

# Set both to have `prisma/seed.ts` create/update a PLATFORM_ADMIN account.
# There is no fallback default password — if either var is missing, the
# seed skips platform admin creation and logs a safe message instead of
# failing.
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=

# =============================================================================
# OPTIONAL — AI module (app works fully without this)
# =============================================================================

# Anthropic API key used for AI question generation and AI draft essay
# marking. Without it, those features return a safe "not configured" error;
# nothing else in the app is affected.
ANTHROPIC_API_KEY=

# =============================================================================
# OPTIONAL — Academic Integrity Network Evidence v1
# =============================================================================

# HMAC-SHA256 salt used to pseudonymise IP addresses for comparison. If unset,
# a random per-process salt is used (consistent within one server restart,
# changes on redeploy). Set to a stable random hex string in production so IP
# hashes are consistent across deployments and can be compared over time.
NETWORK_EVIDENCE_SALT=

# ── IP Geolocation (optional) ────────────────────────────────────────────────
#
# GEOLOCATION_PROVIDER controls whether IP-based location is looked up.
# The default is "none" — no external call, no IP address sent anywhere,
# country/region/city show "UNAVAILABLE" in the evidence report.
#
# Supported values:
#   none    (default) — no geolocation, UNAVAILABLE
#   ipapi   — https://ipapi.co — free tier, no API key required for basic use;
#             set GEOLOCATION_API_KEY for higher rate limits
#
# BEFORE setting a non-none provider in production, you MUST:
#   1. Review the provider's Terms of Service and data retention policy.
#   2. Determine if the provider must be listed as a privacy sub-processor
#      under your institution's privacy framework.
#   3. Update the student privacy notice to name the provider.
#   4. Obtain institutional approval for sending student IP addresses to
#      a third-party service.
# Do NOT enable a provider unless the above steps are complete.
GEOLOCATION_PROVIDER=none

# API key for the geolocation provider (optional for ipapi free tier).
# Required for paid plans or higher rate limits.
GEOLOCATION_API_KEY=

# Timeout for geolocation provider requests in milliseconds.
# Default: 2000ms. Must be short enough not to delay exam flow noticeably.
GEOLOCATION_TIMEOUT_MS=2000
